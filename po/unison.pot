#: ../src/abort.ml:25
msgid "maximum number of errors before a directory transfer is aborted"
msgstr ""

#: ../src/abort.ml:26
msgid ""
"This preference controls after how many errors Unison aborts a directory "
"transfer.  Setting it to a large number allows Unison to transfer most of a "
"directory even when some files fail to be copied.  The default is 1.  If the "
"preference is set too high, Unison may take a long time to abort in case of "
"repeated failures (for instance, when the disk is full)."
msgstr ""

